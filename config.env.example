# ============================================================
# config.env.example
# Copy this file to config.env and fill in ALL values before
# running any deploy script.
#
# Usage:
#   cp config.env.example config.env
#   nano config.env          # fill in your values
#   source config.env        # load into current shell
# ============================================================

# ── Step 0: Cluster discovery ───────────────────────────────

# GPU node names (space-separated if multiple)
MY_GPU_NODE_NAMES="gpu-node-01"

# GPUs per node (e.g. 8)
MY_GPU_COUNT_PER_NODE="8"

# Total free GPUs available to you
MY_FREE_GPUS="8"

# GPU type: "H200" or "H100"
MY_GPU_TYPE="H200"

# GPU VRAM in GB: 141 for H200, 80 for H100
MY_GPU_MEMORY_GB="141"

# Tensor parallel size:
#   H200 → 2 (minimum), 4 (recommended)
#   H100 → 4 (minimum)
MY_TENSOR_PARALLEL_SIZE="2"

# The taint key on your GPU nodes (check: kubectl describe nodes | grep Taint)
# Common values: "nvidia.com/gpu" or leave empty if no taint
MY_GPU_TAINT_KEY="nvidia.com/gpu"

# ── Namespace ────────────────────────────────────────────────

# Kubernetes namespace where everything will be deployed
# Use an existing one or "llm-serving" (created by scripts/deploy-all.sh)
MY_NAMESPACE="llm-serving"

# ── Storage ─────────────────────────────────────────────────

# Storage class for the 300 Gi model PVC
# Run: kubectl get storageclass  — pick the (default) one
MY_STORAGE_CLASS="standard"

# ── ClearML ─────────────────────────────────────────────────

MY_CLEARML_NAMESPACE="clearml"
MY_CLEARML_API_URL="http://clearml-api:8008"
MY_CLEARML_WEB_URL="http://clearml-web:8080"
MY_CLEARML_FILES_URL="http://clearml-files:8081"
MY_CLEARML_ACCESS_KEY="YOUR_CLEARML_ACCESS_KEY"
MY_CLEARML_SECRET_KEY="YOUR_CLEARML_SECRET_KEY"

# ── Container images (Step 0.7 / 0.7b) ──────────────────────
#
# If your cluster has internet access, use the public defaults below.
# If your cluster is air-gapped, replace with your internal registry paths.
# See 00-cluster-discovery/DISCOVERY.md §0.7a and §0.7b for the push procedure.

# "yes" or "no"
MY_CLUSTER_HAS_INTERNET="yes"

# Your internal container registry (ignored when MY_CLUSTER_HAS_INTERNET=yes)
# e.g. "artifactory.corp.com/docker"  or  "123456.dkr.ecr.us-east-1.amazonaws.com"
MY_CONTAINER_REGISTRY="docker.io"

# Image pull secret name in MY_NAMESPACE (set to "none" if not needed)
# e.g. "registry-credentials"
MY_IMAGE_PULL_SECRET="none"

# Full image paths used in Job and Deployment YAMLs.
# For public internet clusters, keep the defaults below.
# For air-gapped clusters, prefix each with $MY_CONTAINER_REGISTRY/
MY_VLLM_IMAGE="vllm/vllm-openai:latest"
MY_LITELLM_IMAGE="ghcr.io/berriai/litellm:main-stable"
MY_PYTHON_IMAGE="python:3.11-slim"

# ── Hugging Face ─────────────────────────────────────────────

# HF token with read access to meta-llama/Llama-3.3-70B-Instruct
# Get one at https://huggingface.co/settings/tokens
# Ensure you have accepted the license at https://huggingface.co/meta-llama/Llama-3.3-70B-Instruct
HF_TOKEN="hf_YOUR_TOKEN_HERE"

# ── LiteLLM ─────────────────────────────────────────────────

# Master API key for LiteLLM proxy — change this to something secret
LITELLM_MASTER_KEY="sk-change-me-to-a-real-secret-key"
